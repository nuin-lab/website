// Elements
import Anchor from '../elements/Anchor.astro';

// Constants
import { navItems } from '../constants/links.constants';

const path = Astro.url.pathname;

const LogoElem = path === '/' ? 'h1' : 'div';
---

<header>
  <LogoElem>
    <a href="/" data-anim="blink">
      <span aria-hidden="true" data-lang="en">nuin/ab</span>
      <span class="sr-only">nuin lab</span>
    </a>
  </LogoElem>

  <nav>
    <ul data-lang="en">
      {navItems.map((item) => (
        <li>
          <Anchor href={`/${item.toLowerCase()}`}>{item}</Anchor>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;

    position: sticky;
    top: 0;

    padding-inline: 1rem;

    height: var(--hdr-ht);

    border-block: 1px solid var(--black);

    > h1,
    > div {
      font-size: 1.25em;
      font-weight: 500;
      line-height: 1;
    }
  }

  ul {
    display: flex;

    gap: 1rem;
  }

  li {
    font-weight: 600;
  }
</style>
