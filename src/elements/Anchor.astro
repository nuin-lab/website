// Tpypes
import type { HTMLAttributes } from 'astro/types';

const { class: className, ...rest }: HTMLAttributes<'a'> = Astro.props;
---

<!-- biome-ignore format: 視認性のための意図的な改行 -->
<!-- biome-ignore lint/a11y/useAnchorContent: BiomeのAstro部分サポートによる誤検知 -->
<a {...rest} data-anim="blink">
  <slot />
</a>

<style>
  @media (hover: hover) and (pointer: fine) {
    a {
      position: relative;

      &::before {
        content: "";

        position: absolute;
        left: 0;
        bottom: -2px;

        width: 100%;
        height: 1px;

        background-color: currentColor;

        scale: 0 1;
        transform-origin: center;

        transition: scale 0.2s;
      }

      &:hover::before {
        scale: 1;
      }
    }
  }
</style>
