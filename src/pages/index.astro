import { getAvailableArticles } from '../lib/query/articles';
import { format } from '../utils/date';

// Types
import type { CardData, CarouselItemData } from '../types/article.types';

// Layouts
import Page from '../layouts/Page.astro';

// Components
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import Sidebar from './_components/Sidebar.astro';

// Sections
import Hero from './_sections/Hero.astro';
import LatestArticle from './_sections/LatestArticle.astro';

const availableArticles = await getAvailableArticles();

const featuredArticles: CarouselItemData[] = availableArticles.flatMap(({ id, data }) => {
  if (!data.featured) {
    return [];
  }

  return {
    title: data.title,
    slug: id,
    img: data.img,
  };
});

const latestArticles: CardData[] = availableArticles.flatMap(({ id, data }) => {
  const publishedAt = format(data.publishedAt);

  if (!publishedAt) {
    if (import.meta.env.DEV) {
      return [];
    }

    throw new Error('An unexpected error has occurred');
  }

  return {
    title: data.title,
    date: publishedAt,
    slug: id,
    img: data.img,
  };
});
---

<Page title="Home" description="Template page">
  <Hero carouselItems={featuredArticles} />

  <Header />

  <main id="main">
    <Sidebar />
    <LatestArticle articles={latestArticles} />
  </main>

  <Footer />
</Page>

<style>
  main {
    border-bottom: 1px solid;

    @media screen and (width < 1100px) {
      display: flex;
      flex-direction: column-reverse;
    }

    @media screen and (width >= 1100px) {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
  }

  :global(hgroup) {
    display: flex;
    flex-direction: column-reverse;

    color: transparent;

    -webkit-text-stroke: 2px var(--black-50);

    pointer-events: none;
    user-select: none;

    :global(h2) {
      line-height: 1;

      @media screen and (width < 700px) {
        font-size: 3.75rem;
      }

      @media screen and (width >= 700px) {
        font-size: 8rem;
      }

      @media screen and (width >= 1100px) {
        font-size: 14rem;
      }
    }

    :global(p) {
      font-weight: 700;

      @media screen and (width < 700px) {
        margin-bottom: 0.5rem;

        font-size: 2rem;
      }

      @media screen and (width >= 700px) {
        margin: 0 0.5rem 0.5rem;

        font-size: 3rem;
      }

      @media screen and (width >= 1100px) {
        margin: 0 0.75rem 1.5rem;

        font-size: 4rem;
      }
    }
  }

  :global(.expanded) {
    letter-spacing: 0.04em;
  }
</style>
