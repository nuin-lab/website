// Layouts
import Page from '../layouts/Page.astro';

// Components
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import Sidebar from './_components/Sidebar.astro';
import LatestArticle from './_components/LatestArticle.astro';

// Sections
import Hero from './_sections/Hero.astro';
---

<Page title="Home" description="Template page">
  <Hero />

  <Header />

  <main id="main">
    <Sidebar />
    <LatestArticle />
  </main>

  <Footer />
</Page>

<style>
  main {
    display: grid;
    grid-template-columns: repeat(4, 1fr);

    border-bottom: 1px solid;
  }

  :global(hgroup) {
    display: flex;
    flex-direction: column-reverse;

    color: transparent;

    -webkit-text-stroke: 2px var(--black-50);

    pointer-events: none;
    user-select: none;

    :global(h2) {
      font-size: 14rem;
      line-height: 1;
    }

    :global(p) {
      margin: 0 0.75rem 1.5rem;

      font-size: 4rem;
      font-weight: 700;
    }
  }

  :global(.expanded) {
    letter-spacing: 0.04em;
  }
</style>
