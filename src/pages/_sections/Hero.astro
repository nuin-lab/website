<section id="hero">
  <a href="#header" data-visible="focus">おすすめ記事をスキップ</a>

  <hgroup>
    <h2 data-lang="en">Featured</h2>
    <p>おすすめ記事</p>
  </hgroup>
</section>

<style>
  #hero {
    position: relative;

    height: var(--vh-remain);
  }

  [data-visible="focus"] {
    margin: 0.5em;
  }

  hgroup {
    display: flex;
    flex-direction: column-reverse;

    position: absolute;
    top: 50%;
    translate: 0 -50%;

    color: transparent;

    -webkit-text-stroke: 2px var(--black-50);

    pointer-events: none;
    user-select: none;

    h2 {
      font-size: 14rem;
      line-height: 1;
      letter-spacing: 0.04em;
    }

    p {
      margin-block: 0 2rem;
      margin-inline: 0.75rem;

      font-size: 4rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.04em;
    }
  }
</style>
