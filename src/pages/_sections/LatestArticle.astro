import { getLatestArticles } from '../../lib/query/articles';

// Components
import Card from '../_components/Card.astro';
---

<section id="latest">
  <div>
    <div>
      <hgroup>
        <h2 class="expanded" data-lang="en">Latest</h2>
        <p class="expanded">最新記事</p>
      </hgroup>
    </div>
  </div>

  <ul>
    {(await getLatestArticles()).map((data) => (
      <li>
        <Card {...data} />
      </li>
    ))}

    <li>
      <a href="blog/2" class="btn-more" data-anim="blink">
        <span>View more</span>
        <span>記事一覧</span>
      </a>
    </li>
  </ul>
</section>

<style>
  #latest {
    display: grid;
    grid-column: 2 / 5;
    grid-template-columns: subgrid;

    position: relative;

    > div {
      position: absolute;

      width: 100%;
      height: 100%;

      pointer-events: none;
      z-index: -1;

      > div {
        display: grid;
        place-content: center;

        position: sticky;
        top: var(--hdr-ht);

        height: var(--vh-remain);
      }
    }
  }

  hgroup {
    align-items: center;

    h2 {
      text-transform: uppercase;
    }
  }

  ul {
    display: grid;

    @media screen and (width < 700px) {
      grid-template-columns: repeat(1, 1fr);
    }

    @media screen and (width >= 700px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media screen and (width >= 1100px) {
      grid-column: 1 / 4;
      grid-template-columns: subgrid;
    }
  }

  li {
    @media screen and (width >= 700px) {
      &:not(:nth-of-type(2n)) {
        border-right: 1px solid;
      }
    }

    @media screen and (width < 1100px) {
      &:not(:nth-last-of-type(-n + 1)) {
        border-bottom: 1px solid;
      }
    }

    @media screen and (width >= 1100px) {
      &:not(:nth-of-type(3n)) {
        border-right: 1px solid;
      }

      &:not(:nth-last-of-type(-n + 3)) {
        border-bottom: 1px solid;
      }
    }

    &:has(.btn-more) {
      background-color: var(--black);
      color: var(--white);

      @media screen and (width < 700px) {
        aspect-ratio: 3 / 2;
      }
    }
  }

  .btn-more {
    display: flex;
    flex-direction: column-reverse;
    justify-content: center;
    align-items: center;

    gap: 0.5rem;

    height: 100%;
  }
</style>
