interface Props {
  title: string;
  date: string;
  slug: string;
  img: string;
}

const { title, date, slug, img } = Astro.props;
---

<script>
  function isWithinOneWeek(date: string): boolean {
    const msPerDay = 24 * 60 * 60 * 1000;

    return Math.abs((new Date(date).getTime() - Date.now()) / msPerDay) <= 7;
  }

  document.addEventListener('DOMContentLoaded', () => {
    for (const meta of document.querySelectorAll('.meta')) {
      if (!isWithinOneWeek((meta.children[1] as HTMLTimeElement).dateTime)) {
        return;
      }

      // Add 'New' indicator
      const indicator = document.createElement('div');
      indicator.classList = 'indicator';
      indicator.dataset.lang = 'en';
      indicator.textContent = 'New';

      meta.insertAdjacentElement('beforeend', indicator);
    }
  });
</script>

<article>
  <div class="meta">
    <h3><a href={slug}>{title}</a></h3>
    <time datetime={date} class="expanded" data-lang="en">{date.replaceAll('-', '.')}</time>
  </div>
  <picture><img src={img} alt={`${title}のサムネイル`}></picture>
</article>

<style>
  article {
    display: grid;

    position: relative;

    aspect-ratio: 53 / 57;
  }

  .meta {
    display: flex;
    flex-direction: column-reverse;
    justify-content: start;

    grid-area: 1 / 1 / 2 / 2;

    padding: 1rem;
    gap: 0.2rem;
  }

  h3 {
    font-size: 1rem;
    font-weight: 500;
  }

  a::before {
    content: "";
    display: block;

    position: absolute;
    inset: 0;

    width: 100%;
    height: 100%;
  }

  time {
    margin: 0 0.2em;

    font-size: 0.75em;
    font-weight: 700;
  }

  :global(.indicator) {
    position: absolute;
    top: 0;
    right: 0;

    padding: 0.25rem 1em;

    background-color: var(--black);
    color: var(--white);

    font-size: 0.75em;
    font-weight: 700;

    pointer-events: none;
  }

  picture {
    display: grid;
    place-content: center;
    grid-area: 1 / 1 / 3 / 2;

    padding: 4rem 3rem;
  }

  img {
    width: 100%;
    aspect-ratio: 1;

    object-fit: contain;
  }
</style>
