interface Props {
  title: string;
  date: string;
  slug: string;
  img: string;
}

const { title, date, slug, img } = Astro.props;
---

<article>
  <div class="meta">
    <h3><a href={slug}>{title}</a></h3>
    <time datetime={date} data-lang="en">{date.replaceAll('-', '.')}</time>
  </div>
  <picture><img src={img} alt={`${title}のサムネイル`}></picture>
</article>

<style>
  article {
    display: grid;

    position: relative;

    aspect-ratio: 53 / 57;
  }

  .meta {
    display: flex;
    flex-direction: column-reverse;
    justify-content: start;

    grid-area: 1 / 1 / 2 / 2;

    padding: 1rem;
    gap: 0.2rem;
  }

  h3 {
    font-size: 1rem;
    font-weight: 500;
  }

  a::before {
    content: "";
    display: block;

    position: absolute;
    inset: 0;

    width: 100%;
    height: 100%;
  }

  time {
    margin: 0 0.2em;

    font-size: 0.75em;
    font-weight: 700;

    letter-spacing: 0.04em;
  }

  picture {
    display: grid;
    place-content: center;
    grid-area: 1 / 1 / 3 / 2;

    padding: 4rem 3rem;
  }

  img {
    width: 100%;
    aspect-ratio: 1;

    object-fit: contain;
  }
</style>
