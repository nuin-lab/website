interface Props {
  articles: {
    title: string;
    slug: string;
    img: string;
  }[];
}

const { articles } = Astro.props;
---

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('carousel');

    let velocity = 0;

    function startInertiaScroll() {
      const friction = 0.1; // 摩擦係数

      function inertiaScroll() {
        carousel?.scrollBy({
          left: -velocity,
        });

        velocity *= 1 - friction;

        if (Math.abs(velocity) > 0.1) {
          requestAnimationFrame(inertiaScroll);
        }
      }

      inertiaScroll();
    }

    carousel?.addEventListener('pointerdown', (event) => {
      if (event.button !== 0) {
        return;
      }

      event.preventDefault();

      let isDragging = false;

      let lastX = event.pageX;
      const startX = lastX;
      const scrollStartX = carousel?.scrollLeft;
      velocity = 0; // 慣性スクロール中なら停止

      function dragMove(event: PointerEvent) {
        isDragging = true;
        carousel?.setAttribute('data-dragging', `${isDragging}`);

        const deltaX = event.pageX - startX;
        carousel?.scrollTo({
          left: scrollStartX - deltaX,
        });

        velocity = event.pageX - lastX;
        lastX = event.pageX;
      }

      function dragEnd() {
        if (isDragging) {
          isDragging = false;
          carousel?.setAttribute('data-dragging', `${isDragging}`);

          startInertiaScroll();
        }

        document.removeEventListener('pointermove', dragMove);
        setTimeout(() => {
          document.removeEventListener('pointerup', dragEnd);
          carousel?.removeEventListener('pointerleave', dragEnd);
        }, 200);
      }

      document.addEventListener('pointermove', dragMove);
      document.addEventListener('pointerup', dragEnd);
      carousel?.addEventListener('pointerleave', dragEnd);
    });
  });
</script>

<ul id="carousel" data-dragging="false">
  {articles.map(({title, slug, img}) => (
    <li>
      <a href={slug}>
        <span data-visible="sr">{title}</span>
      </a>
      <img src={img} alt={`${title}のサムネイル`} />
    </li>
  ))}
</ul>

<style>
  ul {
    display: flex;

    padding: 8rem 6rem;
    padding-left: 16rem;
    gap: 6rem;

    height: 100%;

    line-height: 0;

    cursor: grab;

    overflow: auto;
    scrollbar-width: none;

    &[data-dragging="true"] {
      cursor: grabbing;

      a {
        pointer-events: none;
      }
    }
  }

  li {
    position: relative;
  }

  a::before {
    content: "";

    position: absolute;
    inset: 0;
  }

  img {
    height: 100%;
    aspect-ratio: 1;

    object-fit: contain;

    pointer-events: none;
    user-select: none;
  }

  @media (hover: hover) and (pointer: fine) {
    a:is(:hover, :focus) + img {
      scale: 1;
    }

    img {
      scale: 0.975;

      transition: scale var(--duration) ease-in-out;
    }
  }
</style>
