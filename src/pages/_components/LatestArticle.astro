];
---

<section id="latest">
  <div>
    <div>
      <hgroup>
        <h2 data-lang="en">Latest</h2>
        <p>最新記事</p>
      </hgroup>
    </div>
  </div>

  <ul>
    {articles.map(({tag: _tag, ...data}) => (
      <li>
        <Card {...data} />
      </li>
    ))}

    <li>
      <a href="blog/2" class="btn-more">
        <span>View more</span>
        <span>記事一覧</span>
      </a>
    </li>
  </ul>
</section>

<style>
  #latest {
    display: grid;
    grid-column: 2 / 5;
    grid-template-columns: subgrid;

    position: relative;

    > div {
      position: absolute;

      width: 100%;
      height: 100%;

      pointer-events: none;
      z-index: -1;

      > div {
        display: grid;
        place-content: center;

        position: sticky;
        top: var(--hdr-ht);

        height: var(--vh-remain);
      }
    }
  }

  hgroup {
    align-items: center;

    h2 {
      text-transform: uppercase;
    }
  }

  ul {
    display: grid;
    grid-column: 1 / 4;
    grid-template-columns: subgrid;
  }

  li {
    &:not(:nth-of-type(3n)) {
      border-right: 1px solid;
    }

    &:not(:nth-last-of-type(-n + 3)) {
      border-bottom: 1px solid;
    }
  }

  .btn-more {
    display: flex;
    flex-direction: column-reverse;
    justify-content: center;
    align-items: center;

    gap: 0.5rem;

    height: 100%;

    background-color: var(--black);
    color: var(--white);
  }
</style>
