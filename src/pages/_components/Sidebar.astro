const tags: string[] = ['HTML', 'CSS', 'JavaScript/TypeScript'];
---

<div id="sidebar">
  <h2 data-lang="en">Tags</h2>
  <ul data-lang="en">
    {tags.map((tag) => (
      <li>
        <a href={`tags/${tag.toLowerCase().replaceAll('/', '-')}`}>{tag}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  #sidebar {
    border-right: 1px solid;
  }

  h2 {
    display: flex;
    align-items: center;

    padding: 0 1rem;

    height: var(--hdr-ht);

    background-color: var(--black);
    color: var(--white);

    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  ul {
    display: flex;

    padding: 1rem;
    gap: 1rem;
  }
</style>
