// Elements
import Anchor from '../../elements/Anchor.astro';

const tags: string[] = ['HTML', 'CSS', 'JavaScript/TypeScript'];
---

<div id="sidebar">
  <div>
    <h2 data-lang="en">Tags</h2>

    <a href="#latest" data-visible="focus">タグリストをスキップ</a>
  </div>

  <ul data-lang="en">
    {tags.map((tag) => (
      <li>
        <Anchor href={`tags/${tag.toLowerCase().replaceAll('/', '-')}`}>{tag}</Anchor>
      </li>
    ))}
  </ul>
</div>

<style>
  #sidebar {
    border-right: 1px solid;

    > div {
      display: flex;
      align-items: center;

      position: relative;

      padding: 0 1rem;

      height: var(--hdr-ht);

      background-color: var(--black);
      color: var(--white);
    }
  }

  h2 {
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  [data-visible="focus"] {
    position: absolute;
  }

  ul {
    display: flex;

    padding: 1rem;
    gap: 1rem;
  }
</style>
